NODE_ENV=development
PORT=60000

# CORS - Frontend URL (production only, dev allows all origins)
FRONTEND_URL=https://my-blog.com

# Database (configured in Story 1.4)
# For local PostgreSQL without password: postgresql://your_username@localhost:5432/my_blog?schema=public
# For PostgreSQL with password: postgresql://your_username:your_password@localhost:5432/my_blog?schema=public
DATABASE_URL=postgresql://your_username@localhost:5432/my_blog?schema=public

# JWT (will be configured in Story 2.3)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
