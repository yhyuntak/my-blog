NODE_ENV=development
PORT=60000

# CORS - Frontend URL (production only, dev allows all origins)
FRONTEND_URL=https://my-blog.com

# Database (will be configured in Story 1.4)
DATABASE_URL=postgresql://user:password@localhost:5432/my_blog

# JWT (will be configured in Story 2.3)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
